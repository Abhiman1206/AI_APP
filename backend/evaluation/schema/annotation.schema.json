{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://intelli-credit.local/annotation.schema.json",
  "title": "ExtractionAnnotation",
  "type": "object",
  "required": [
    "doc_id",
    "document_type",
    "scan_type",
    "fields"
  ],
  "properties": {
    "doc_id": {"type": "string", "minLength": 1},
    "document_type": {
      "type": "string",
      "enum": ["bank", "gst", "financial", "other"]
    },
    "scan_type": {
      "type": "string",
      "enum": ["scanned", "native", "mixed"]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "value"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "value": {},
          "unit": {"type": ["string", "null"]},
          "criticality": {
            "type": "string",
            "enum": ["critical", "important", "nice_to_have"]
          },
          "page": {"type": ["integer", "null"], "minimum": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
